build.log

# Disk images (too large for git)
*.img
*.img.xz

# WiFi credentials + user setup — edit these with real values, do not commit
settings/network-config
settings/user-data

# Local AI-assistant context / tooling (not shared)
CLAUDE.md
.claude/

# macOS
.DS_Store

# Windows
Thumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/