# Build outputs (generated by ./build.sh — do not commit)
output/*
!output/.gitkeep
build.log

# Disk images (too large for git)
*.img
*.img.xz

# User setup — edit with real values; do not commit your filled-in version.
# settings/network-config ships with placeholders (JOUW_WIFI_NAAM/...), so it IS
# tracked: the build needs it and a fresh clone must build. Put REAL credentials
# in the network-config on the flashed boot partition, not in the repo copy.
settings/user-data

# Local AI-assistant context / tooling (not shared)
CLAUDE.md
.claude/

# macOS
.DS_Store

# Windows
Thumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/